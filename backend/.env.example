# ── App ─────────────────────────────────────────────────────
APP_ENV=local
SEED_DEMO_DATA=false

# ── Repository ──────────────────────────────────────────────
# "memory"   — in-memory store (used in tests; default for quick local dev)
# "postgres" — PostgreSQL via psycopg (talks to Supabase Postgres)
REPOSITORY_TYPE=memory

# ── Database (used when REPOSITORY_TYPE=postgres) ───────────
# Supabase CLI default. Override if you change ports in supabase/config.toml.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres

# ── Supabase Auth ──────────────────────────────────────────
# Run `supabase status -o env` after `supabase start` to print real values.
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ── Storage buckets (created by supabase/migrations/002_*.sql) ──
SUPABASE_STORAGE_BUCKET_RECEIPTS=receipts
SUPABASE_STORAGE_BUCKET_VOICE_NOTES=voice-notes

# ── Optional integrations ──────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://saia.gwdg.de/v1       # any OpenAI-compatible /v1 root (e.g. http://127.0.0.1:1234/v1 for LM Studio)
# OPENAI_TRANSCRIPTION_MODEL=whisper-large-v2   # model id exposed by the provider
# AI_TRANSCRIPTION_PROVIDER=openai              # openai | mock
# CHAT_AI_BASE_URL=https://chat-ai.academiccloud.de/v1
# CHAT_AI_API_KEY=                               # falls back to OPENAI_API_KEY if unset
# CHAT_AI_EXTRACTION_MODEL=qwen3-30b-a3b-instruct-2507
# AI_EXTRACTION_PROVIDER=llm                    # llm | regex
# WHATSAPP_PROVIDER=mock

# ── AI merchant-chat (Phase 13) ────────────────────────────
# MERCHANT_CHAT_PROVIDER=chat_ai        # chat_ai | anthropic | mock | stub
# CHAT_AI_MERCHANT_CHAT_MODEL=qwen3-30b-a3b-instruct-2507
# MERCHANT_CHAT_MODEL=claude-sonnet-4-6  # only used when MERCHANT_CHAT_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# AI_MERCHANT_CHAT_DAILY_LIMIT=50
# MERCHANT_CHAT_LOG_SALT=change-me-in-production
