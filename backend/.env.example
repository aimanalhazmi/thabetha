# ── App ───────────────────────────────────────────────────────
APP_ENV=local
SEED_DEMO_DATA=false

# ── Repository ─────────────────────────────────────────────────
# "memory"   — in-memory store (default; used in tests)
# "postgres" — PostgreSQL via psycopg (used in Docker)
REPOSITORY_TYPE=memory

# ── Database (required when REPOSITORY_TYPE=postgres) ──────────
DATABASE_URL=postgresql://thabetha:thabetha_local@localhost:5432/thabetha

# ── GoTrue Auth (required when REPOSITORY_TYPE=postgres) ───────
GOTRUE_URL=http://localhost:9999
SUPABASE_JWT_SECRET=super-secret-jwt-token-for-local-dev-min-32-chars!!

# ── Supabase Cloud (optional; for cloud deployment) ────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=

# ── Optional integrations ──────────────────────────────────────
# OPENAI_API_KEY=
# WHATSAPP_PROVIDER=mock
