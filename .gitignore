# =============================================================================
# Thabetha – .gitignore
# Stack: Python 3.12 / FastAPI / uv  +  React / TypeScript / Vite  +  Docker
# =============================================================================

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
.envrc

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# ── Editor / IDE ──────────────────────────────────────────────────────────────
# VS Code (workspace-level settings are personal; commit only .code-workspace if desired)
.vscode/
# JetBrains / PyCharm / IntelliJ / Cursor
.idea/
*.iml
# Vim / Neovim swap files
*.swp
*.swo
*~

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# uv – keep uv.lock committed (ensures reproducible CI/Docker builds)
# uv.lock  ← do NOT ignore

# Build / packaging artefacts
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
sdist/

# Test & quality tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.lcov
.tox/
.nox/
.hypothesis/

# Misc Python tool artefacts
pip-log.txt
*.log
tempCodeRunnerFile.py
.pypirc

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/

# Vite build output (generated; never commit)
frontend/dist/
frontend/.vite/

# TypeScript incremental build info
*.tsbuildinfo

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Docker ────────────────────────────────────────────────────────────────────
# Don't ignore docker-compose.yml – it's source.
# Ignore any locally overridden compose files that may hold credentials.
docker-compose.override.yml
docker-compose.local.yml

# ── Supabase local CLI ────────────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/

# ── Misc ──────────────────────────────────────────────────────────────────────
# Byte-order mark artefacts, OS thumbnails, etc.
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/